{
  "expo": {
    "name": "CPF Mobile",
    "slug": "cpf-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cpf.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CPF needs your location to send panic alerts with your GPS coordinates.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "CPF needs your location to send panic alerts with your GPS coordinates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.cpf.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "scheme": "cpf",
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CPF needs your location to send panic alerts."
        }
      ]
    ]
  }
}
